# =====================================================================
# OECS Post-Secondary EduData — environment template
# =====================================================================
# Copy to .env (or .env.local). Next.js loads both; .env.local overrides .env.
#
# PHASE 1 — Strip & validate (offline, browser-only)
#   No variables required. PII stays in session storage.
#
# PHASE 2 — Submit / approvals / OECS aggregates (online)
#   Supabase required for POST /api/submissions and minister approval queue.
#   Run db/setup.ps1 once after filling SUPABASE_DB_PASSWORD (or SEED_DATABASE_URL).
# =====================================================================

# ---- Supabase (Dashboard → Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# JWT Secret — same page; needed for demo persona tokens (/api/scoped)
SUPABASE_JWT_SECRET=

# ---- Database migrations (db/setup.ps1 or node db/setup.mjs) ----
# Dashboard → Connect → Session pooler (IPv4). Direct db.* host is IPv6-only.
SUPABASE_DB_PASSWORD=
# Auto-discovery tries aws-0/1/2 pooler clusters; override if Connect shows a specific host:
# SUPABASE_DB_POOLER_HOST=aws-1-us-east-1.pooler.supabase.com
# Or paste the full session pooler URL from Connect:
# SEED_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ---- Auth (NextAuth / Auth.js) ----
# Generate: npx auth secret
AUTH_SECRET=
# Set true when Auth0 vars below are configured
NEXT_PUBLIC_AUTH0_ENABLED=false
# AUTH0_ISSUER=https://YOUR_TENANT.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=

# ---- Admin portal (/admin) & validation layer ----
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_SECRET=
# Optional — gate exe RULI key registration; empty = open demo registration
RULI_REGISTER_SECRET=

# ---- Optional: legacy scheduled ingest (not needed for browser upload) ----
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# CRON_SECRET=

# ---- Demo sign-in emails (seeded by db/setup.ps1) ----
# admin@demo.local          → OECS admin
# minister.lc@demo.local      → country approval (Saint Lucia)
# minister.gd@demo.local      → country approval (Grenada, no L2 gate)
# lecturer.lc@demo.local      → institution upload (LC-CC)
# lecturer.ag@demo.local      → institution upload (AG-CC)
