# =====================================================================
# ENV  --  copy to .env.local (Next.js) and set in Vercel project vars
# =====================================================================

# ---- Supabase (runtime data layer) ----
# Project URL + keys from Supabase Dashboard -> Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
# anon (publishable) key. Safe in the browser; used by the user-scoped client
# together with a per-request JWT (RLS enforced).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role (secret) key. BYPASSES RLS. SERVER-ONLY -- never NEXT_PUBLIC_*,
# never sent to the browser. Used by all server-trusted paths.
SUPABASE_SERVICE_ROLE_KEY=
# Project JWT secret (Settings -> API -> JWT Settings). Used ONLY to mint the
# short-lived demo-persona tokens. Server-only.
SUPABASE_JWT_SECRET=

# ---- DB migration / seed scripts (build-time only, via pg) ----
# Supabase DIRECT connection string (Settings -> Database -> Connection string,
# the non-pooled one on port 5432). Used by db/setup.ps1, db/seed.mjs,
# db/gen-key.mjs, db/add-sheet.mjs. The app runtime does NOT use this.
#   postgres://postgres:<db-password>@db.<ref>.supabase.co:5432/postgres
SEED_DATABASE_URL=

# ---- Google Sheets ingest (cron) ----
# Service account that schools share their sheet with (Viewer).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# PEM private key. Keep the literal \n escapes on one line; the app un-escapes them.
GOOGLE_PRIVATE_KEY=
# Shared secret protecting /api/cron/sync-sheets. Vercel Cron sends it as
# "Authorization: Bearer <CRON_SECRET>". Generate any long random string.
CRON_SECRET=

# ---- Auth0 SSO (NextAuth v5 / Auth.js) ----
# Auth0 is the login IdP AND a Supabase third-party auth provider. The Auth0
# access token must carry an `email` claim (add via an Auth0 Action) so
# app_current_user() can resolve the caller; otherwise RLS reads return 0 rows.
# AUTH0_ISSUER = "https://" + the Domain value from Auth0 Settings (no trailing slash).
AUTH0_ISSUER=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Generate with: npx auth secret  (any 32+ char random string)
AUTH_SECRET=

# ---- Admin portal (/admin) ----
# Interim gate for the ingest admin portal until Google SSO is wired.
# Long random string; typed into /admin once. Sent as "Authorization: Bearer".
ADMIN_SECRET=
