# =====================================================================
# ENV  --  copy to .env.local (Next.js) and set in Vercel project vars
# =====================================================================

# Postgres connection string. On Vercel use the POOLED endpoint
# (Neon / Vercel Postgres / Supabase). Example (Neon pooled):
#   postgres://user:pass@ep-xxxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL=

# Seed/admin connection (superuser; bypasses RLS) used by db/seed.mjs,
# db/gen-key.mjs, and db/add-sheet.mjs. Local: postgres://postgres:<pw>@localhost:5432/student_demo
SEED_DATABASE_URL=

# Password for the app_client Postgres role. Must match what db/setup.ps1 created.
# Used by db/setup.ps1; also embedded in DATABASE_URL.
APP_CLIENT_PASSWORD=

# TLS controls for managed Postgres.
#   PGSSL=disable        -> turn TLS off entirely (local dev only)
#   PGSSL_STRICT=true    -> verify the CA chain (default: off, accept provider chain)
# PGSSL=
# PGSSL_STRICT=

# ---- Google Sheets ingest (cron) ----
# Service account that schools share their sheet with (Viewer).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# PEM private key. Keep the literal \n escapes on one line; the app un-escapes them.
GOOGLE_PRIVATE_KEY=
# Shared secret protecting /api/cron/sync-sheets. Vercel Cron sends it as
# "Authorization: Bearer <CRON_SECRET>". Generate any long random string.
CRON_SECRET=

# ---- Auth0 SSO (NextAuth v5 / Auth.js) ----
# Create the Auth0 app and follow SETUP.md recipe 1 to fill these.
# AUTH0_ISSUER = "https://" + the Domain value from Auth0 Settings (no trailing slash).
AUTH0_ISSUER=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Generate with: npx auth secret  (any 32+ char random string)
AUTH_SECRET=

# ---- Admin portal (/admin) ----
# Interim gate for the ingest admin portal until Google SSO is wired.
# Long random string; typed into /admin once. Sent as "Authorization: Bearer".
# Local dev default (also in HANDOFF.md secrets table): RGq6a-f6PRZp6WX3KlDLaWKf
ADMIN_SECRET=
